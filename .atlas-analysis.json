  "keyFeatures": [
    "Dual Spring Boot microservices for Sales (port 3001) and Dispatch (port 3002)",
    "React + Vite frontend served via NGINX in Docker",
    "MySQL 8.0 database with named volume for data persistence",
    "Multi-stage Dockerfiles for optimized container images",
    "Terraform-provisioned 3-tier AWS VPC (web, app, data layers) across two Availability Zones",
    "GitHub Actions CI/CD pipeline that builds, pushes to Amazon ECR, and deploys via AWS SSM",
    "Security group chaining enforcing strict web → app → data traffic flow"
  ],
  "publicApiSurface": [
    "POST /api/v1/ventas — Create a new sale",
    "GET /api/v1/ventas — List all sales",
    "GET /api/v1/ventas/{idVenta} — Get sale by ID",
    "PUT /api/v1/ventas/{idVenta} — Update a sale",
    "DELETE /api/v1/ventas/{idVenta} — Delete a sale",
    "POST /api/v1/despachos — Create a new dispatch",
    "GET /api/v1/despachos — List all dispatches",
    "GET /api/v1/despachos/{idDespacho} — Get dispatch by ID",
    "PUT /api/v1/despachos/{idDespacho} — Update a dispatch",
    "DELETE /api/v1/despachos/{idDespacho} — Delete a dispatch"
  ]
}
